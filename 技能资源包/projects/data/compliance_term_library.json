      "log_level": "critical"
    },
    "中": {
      "action": "自动替换+通知",
      "notification": "业务部门",
      "processing_time": "即时处理",
      "log_level": "warning"
    },
    "低": {
      "action": "标记+建议",
      "notification": "执行人",
      "processing_time": "无需处理",
      "log_level": "info"
    }
  },

